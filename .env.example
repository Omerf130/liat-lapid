# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/liat-lapid

# JWT secret for admin sessions (use a long random string in production)
JWT_SECRET=your-long-random-secret-string

# Admin user created by `npm run seed`
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=change-me-in-production

# Vercel Blob — required for image uploads in admin panel
# Create at: Vercel project → Storage → Blob → Connect
BLOB_READ_WRITE_TOKEN=

# Optional — used for Open Graph canonical URLs (defaults to production URL)
NEXT_PUBLIC_SITE_URL=https://liat-lapid.vercel.app
